import funkin.objects.cutscenes.DialogueCutscene;

function onCreate() {
	if (PlayState.seenCutscene) {
		script.stop();
		return;
	}

	FlxG.sound.playMusic(Paths.music('breakfast'), 0);
	FlxG.sound.music.fadeIn(1, 0, 0.8);

	game.startCutscenes.push(new DialogueCutscene('songs/bopeebo/dialogue.json'));
}


function onCountdownStarted() {
	FlxG.sound.music.fadeOut(1.5, 0, (_) -> FlxG.sound.music.stop());
}
