function setupNote(note:Note){
    note.texture = 'mine';
    note.ignoreNote = true;
    note.hitCausesMiss = true;
    note.noAnimation = true;
    note.noMissAnimation = true;
}

function onGoodNoteHitPost(note:Note){
    FlxG.sound.play(Paths.sound("mineExplode"));
}

function onNoteUpdate(note:Note, elapsed:Float){
	note.typeOffsetAngle = (Conductor.songPosition / 1000) * 75;
}